<Window x:Class="FlaUI.Cli.TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact Form" Height="650" Width="400"
        AutomationProperties.AutomationId="MainWindow">

    <DockPanel>
    <Menu DockPanel.Dock="Top" AutomationProperties.AutomationId="MainMenu">

        <MenuItem Header="File" AutomationProperties.AutomationId="FileMenu">
            <MenuItem Header="New" AutomationProperties.AutomationId="FileNew" Click="MenuItem_Click"/>
            <MenuItem Header="Open" AutomationProperties.AutomationId="FileOpen" Click="MenuItem_Click"/>
            <MenuItem Header="Save" AutomationProperties.AutomationId="FileSave" Click="MenuItem_Click"/>
            <Separator/>
            <MenuItem Header="Exit" AutomationProperties.AutomationId="FileExit" Click="FileExit_Click"/>
        </MenuItem>
        <MenuItem Header="Edit" AutomationProperties.AutomationId="EditMenu">
            <MenuItem Header="Cut" AutomationProperties.AutomationId="EditCut" Click="MenuItem_Click"/>
            <MenuItem Header="Copy" AutomationProperties.AutomationId="EditCopy" Click="MenuItem_Click"/>
            <MenuItem Header="Paste" AutomationProperties.AutomationId="EditPaste" Click="MenuItem_Click"/>
        </MenuItem>
        <MenuItem Header="Help" AutomationProperties.AutomationId="HelpMenu">
            <MenuItem Header="About" AutomationProperties.AutomationId="HelpAbout" Click="HelpAbout_Click"/>
        </MenuItem>
    </Menu>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   AutomationProperties.AutomationId="FormTitle"
                   Text="Contact Form"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="First Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 AutomationProperties.AutomationId="FirstNameInput"
                 x:Name="FirstNameInput"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 AutomationProperties.AutomationId="LastNameInput"
                 x:Name="LastNameInput"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 AutomationProperties.AutomationId="EmailInput"
                 x:Name="EmailInput"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Country:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  AutomationProperties.AutomationId="CountryCombo"
                  x:Name="CountryCombo"
                  Margin="0,0,0,8">
            <ComboBoxItem Content="Finland"/>
            <ComboBoxItem Content="Sweden"/>
            <ComboBoxItem Content="Norway"/>
            <ComboBoxItem Content="Denmark"/>
        </ComboBox>

        <CheckBox Grid.Row="5" Grid.ColumnSpan="2"
                  AutomationProperties.AutomationId="AgreeCheckbox"
                  x:Name="AgreeCheckbox"
                  Content="I agree to the terms"
                  Margin="0,0,0,12"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
            <Button AutomationProperties.AutomationId="SubmitButton"
                    Content="Submit"
                    Width="80" Margin="0,0,8,0"
                    Click="SubmitButton_Click"/>
            <Button AutomationProperties.AutomationId="ClearButton"
                    Content="Clear"
                    Width="80"
                    Click="ClearButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Items:" VerticalAlignment="Top"/>
        <ListBox Grid.Row="7" Grid.Column="1"
                 AutomationProperties.AutomationId="ScrollTestList"
                 x:Name="ScrollTestList"
                 Height="60" Margin="0,0,0,8"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingStackPanel.IsVirtualizing="False">
            <ListBoxItem Content="Item 1" AutomationProperties.AutomationId="ScrollItem1"/>
            <ListBoxItem Content="Item 2" AutomationProperties.AutomationId="ScrollItem2"/>
            <ListBoxItem Content="Item 3" AutomationProperties.AutomationId="ScrollItem3"/>
            <ListBoxItem Content="Item 4" AutomationProperties.AutomationId="ScrollItem4"/>
            <ListBoxItem Content="Item 5" AutomationProperties.AutomationId="ScrollItem5"/>
            <ListBoxItem Content="Item 6" AutomationProperties.AutomationId="ScrollItem6"/>
            <ListBoxItem Content="Item 7" AutomationProperties.AutomationId="ScrollItem7"/>
            <ListBoxItem Content="Item 8" AutomationProperties.AutomationId="ScrollItem8"/>
            <ListBoxItem Content="Item 9" AutomationProperties.AutomationId="ScrollItem9"/>
            <ListBoxItem Content="Item 10" AutomationProperties.AutomationId="ScrollItem10"/>
        </ListBox>

        <Expander Grid.Row="8" Grid.ColumnSpan="2"
                  AutomationProperties.AutomationId="TestExpander"
                  x:Name="TestExpander"
                  Header="More Details"
                  IsExpanded="False"
                  Margin="0,0,0,8">
            <TextBlock AutomationProperties.AutomationId="ExpanderContent"
                       Text="Hidden content revealed by expanding"/>
        </Expander>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Items (V):" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="9" Grid.Column="1"
                  AutomationProperties.AutomationId="VirtualizedCombo"
                  x:Name="VirtualizedCombo"
                  Margin="0,0,0,8"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Standard"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Slider:" VerticalAlignment="Center"/>
        <Slider Grid.Row="10" Grid.Column="1"
                AutomationProperties.AutomationId="TestSlider"
                x:Name="TestSlider"
                Minimum="0" Maximum="100" Value="50"
                IsSnapToTickEnabled="True" TickFrequency="1"
                Margin="0,0,0,8"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="Grid:" VerticalAlignment="Top"/>
        <DataGrid Grid.Row="11" Grid.Column="1"
                  AutomationProperties.AutomationId="TestGrid"
                  x:Name="TestGrid"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  Height="100" Margin="0,0,0,8"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="60"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Rich Text:" VerticalAlignment="Top"/>
        <RichTextBox Grid.Row="12" Grid.Column="1"
                     AutomationProperties.AutomationId="TestRichText"
                     x:Name="TestRichText"
                     IsReadOnly="True"
                     Height="50" Margin="0,0,0,8">
            <FlowDocument>
                <Paragraph>This is sample rich text content for testing the Text pattern.</Paragraph>
            </FlowDocument>
        </RichTextBox>

        <TextBlock Grid.Row="13" Grid.ColumnSpan="2"
                   AutomationProperties.AutomationId="StatusLabel"
                   x:Name="StatusLabel"
                   Text="Ready"
                   FontWeight="SemiBold"/>
    </Grid>
    </DockPanel>
</Window>
